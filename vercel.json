{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "destinations.js",
      "use": "@vercel/static"
    },
    {
      "src": "api/generate-trip.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/geoapify.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/pexels.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/generate-trip",
      "dest": "/api/generate-trip.js"
    },
    {
      "src": "/api/geoapify",
      "dest": "/api/geoapify.js"
    },
    {
      "src": "/api/pexels",
      "dest": "/api/pexels.js"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/destinations.js",
      "dest": "/destinations.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
